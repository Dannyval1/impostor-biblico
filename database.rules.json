{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null && (!data.exists() || data.child('status').val() === 'waiting' || data.child('players').child(auth.uid).exists())",
        ".write": "!data.exists() || data.child('hostId').val() === auth.uid || (auth != null && data.exists() && data.child('players').child(auth.uid).exists() && data.hasChild('playerCount') && ((!newData.exists() && data.child('playerCount').val() === 1) || (newData.exists() && newData.child('hostId').val() === data.child('hostId').val() && newData.child('status').val() === data.child('status').val() && newData.child('playerCount').val() === data.child('playerCount').val() - 1 && !newData.child('players').child(auth.uid).exists())))",
        "hostId": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.exists()",
          ".validate": "newData.isString()"
        },
        "originalHostId": {
          ".write": "!data.exists()",
          ".validate": "newData.isString()"
        },
        "originalHostName": {
          ".write": "!data.exists()",
          ".validate": "newData.isString()"
        },
        "status": {
          ".read": "auth != null",
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().matches(/^(waiting|ready_check|playing|clues|simultaneous_reveal|clue_review|deciding|voting|results|elimination_choice|finished)$/)"
        },
        "playerCount": {
          ".read": "auth != null",
          ".write": "data.parent().child('hostId').val() === auth.uid || (auth != null && data.parent().exists() && data.parent().child('playerNameIndex').child(auth.uid).exists() && newData.isNumber() && ((newData.val() === data.val() + 1 && newData.val() <= data.parent().child('settings').child('maxPlayers').val()) || newData.val() === data.val() - 1))",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "settings": {
          "isPremiumRoom": {
            ".write": "!data.exists()",
            ".validate": "newData.isBoolean()"
          },
          "maxPlayers": {
            ".read": "auth != null",
            ".write": "!data.exists()",
            ".validate": "newData.isNumber() && newData.val() >= 3 && newData.val() <= 30"
          },
          "$other": {
            ".write": "data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": true
          }
        },
        "premiumCategoriesSnapshot": {
          ".write": "!data.exists()",
          ".validate": true
        },
        "nameIndex": {
          "$nameKey": {
            ".read": "auth != null",
            ".write": "auth != null && (!data.exists() || data.val() === auth.uid || data.parent().parent().child('hostId').val() === auth.uid) && (!newData.exists() || newData.val() === auth.uid || data.parent().parent().child('hostId').val() === auth.uid)",
            ".validate": "!newData.exists() || newData.isString()"
          }
        },
        "playerNameIndex": {
          "$playerId": {
            ".read": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "!newData.exists() || newData.isString()"
          }
        },
        "players": {
          "$playerId": {
            ".read": "$playerId === auth.uid || data.parent().parent().child('status').val() === 'waiting' || data.parent().parent().child('players').child(auth.uid).exists()",
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            "clue": {
              ".write": "$playerId === auth.uid || data.parent().parent().parent().child('hostId').val() === auth.uid",
              ".validate": "newData.isString() && newData.val().length <= 50"
            },
            "vote": {
              ".write": "$playerId === auth.uid || data.parent().parent().parent().child('hostId').val() === auth.uid",
              ".validate": "newData.isString()"
            },
            "role": {
              ".read": "$playerId === auth.uid",
              ".write": "data.parent().parent().parent().child('hostId').val() === auth.uid"
            },
            "isConnected": {
              ".write": "$playerId === auth.uid || data.parent().parent().parent().child('hostId').val() === auth.uid"
            },
            "lastSeen": {
              ".write": "$playerId === auth.uid"
            },
            "disconnectedAt": {
              ".write": "$playerId === auth.uid"
            },
            "joinState": {
              ".write": "$playerId === auth.uid || data.parent().parent().parent().child('hostId').val() === auth.uid",
              ".validate": "newData.isString() && newData.val().matches(/^(joining|watching_ad|ready)$/)"
            },
            "joinStateSince": {
              ".write": "$playerId === auth.uid || data.parent().parent().parent().child('hostId').val() === auth.uid",
              ".validate": "newData.isNumber()"
            }
          }
        },
        "reactions": {
          "$reactionId": {
            ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists() && ((newData.exists() && newData.child('playerId').val() === auth.uid) || (!newData.exists() && data.exists() && data.child('playerId').val() === auth.uid))",
            ".validate": "!newData.exists() || (newData.hasChildren(['emoji', 'playerName', 'playerId', 'timestamp']) && newData.child('playerId').val() === auth.uid)"
          }
        },
        "messages": {
          "$messageId": {
            ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists() && ((newData.exists() && newData.child('playerId').val() === auth.uid) || (!newData.exists() && data.exists() && data.child('playerId').val() === auth.uid))",
            ".validate": "!newData.exists() || (newData.hasChild('playerId') && newData.hasChild('playerName') && newData.hasChild('messageKey') && newData.hasChild('timestamp') && newData.child('playerId').val() === auth.uid && newData.child('playerId').isString() && newData.child('playerName').isString() && newData.child('messageKey').isString() && newData.child('messageKey').val().length <= 48 && newData.child('timestamp').isNumber() && (!newData.hasChild('messageText') || (newData.child('messageText').isString() && newData.child('messageText').val().length <= 120)))"
          }
        },
        "currentWord": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "currentImpostors": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "currentRoundStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "cluePhaseStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "votingPhaseStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "turnOrder": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "currentTurnIndex": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "voteCounts": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "isTie": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "lastEliminatedId": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "winner": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "roundDecisionVotes": {
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "newData.isString() && newData.val().matches(/^(go_vote|another_round)$/)"
          },
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "roundDecisionStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "clueReviewReady": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "newData.isBoolean()"
          }
        },
        "clueReviewStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "readyCheckReady": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "newData.isBoolean()"
          }
        },
        "readyCheckStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "readyCheckPreviousStatus": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(waiting|playing|clues|simultaneous_reveal|clue_review|deciding|voting|results|elimination_choice|finished)$/))"
        },
        "voteTieRecovery": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "!newData.exists() || newData.isBoolean()"
        },
        "voteTieStreak": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 3)"
        },
        "finishReason": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(impostor_disconnected|not_enough_players|technical_tie)$/))"
        },
        "clueRound": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "newData.isNumber()"
        },
        "postResultVotes": {
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "newData.isString() && newData.val().matches(/^(play_again|leave)$/)"
          },
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "postResultStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "eliminationChoiceVotes": {
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "newData.isString() && newData.val().matches(/^(continue_same|reveal_impostor)$/)"
          },
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "eliminationChoiceStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "lastActivity": {
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "createdAt": {
          ".read": "auth != null",
          ".write": "!data.exists()"
        }
      }
    }
  }
}
