{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "(auth != null && data.exists() && data.child('status').val() === 'waiting') || data.child('players').child(auth != null ? auth.uid : '').exists() || !data.exists()",
        ".write": "!data.exists() || data.child('hostId').val() === auth.uid || (auth != null && data.exists() && data.child('players').child(auth.uid).exists() && data.hasChild('playerCount') && ((!newData.exists() && data.child('playerCount').val() === 1) || (newData.exists() && newData.child('hostId').val() === data.child('hostId').val() && newData.child('status').val() === data.child('status').val() && newData.child('playerCount').val() === data.child('playerCount').val() - 1 && !newData.child('players').child(auth.uid).exists()))) || (auth != null && data.exists() && newData.exists() && data.hasChild('playerCount') && data.child('status').val() === 'waiting' && newData.child('status').val() === 'waiting' && newData.child('hostId').val() === data.child('hostId').val() && newData.child('playerCount').val() === data.child('playerCount').val() + 1 && !data.child('players').child(auth.uid).exists() && newData.child('players').child(auth.uid).exists())",
        "hostId": {
          ".write": "data.parent().child('hostId').val() === auth.uid || !data.exists()",
          ".validate": "newData.isString()"
        },
        "originalHostId": {
          ".write": "!data.exists()",
          ".validate": "newData.isString()"
        },
        "originalHostName": {
          ".write": "!data.exists()",
          ".validate": "newData.isString()"
        },
        "status": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().matches(/^(waiting|playing|clues|simultaneous_reveal|deciding|voting|results|elimination_choice|finished)$/)"
        },
        "settings": {
          "isPremiumRoom": {
            ".write": "!data.exists()",
            ".validate": "newData.isBoolean()"
          },
          "maxPlayers": {
            ".write": "!data.exists()",
            ".validate": "newData.isNumber() && newData.val() >= 3 && newData.val() <= 20"
          },
          "$other": {
            ".write": "data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": true
          }
        },
        "premiumCategoriesSnapshot": {
          ".write": "!data.exists()",
          ".validate": true
        },
        "players": {
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            "clue": {
              ".write": "$playerId === auth.uid || data.parent().parent().parent().child('hostId').val() === auth.uid",
              ".validate": "newData.isString() && newData.val().length <= 50"
            },
            "vote": {
              ".write": "$playerId === auth.uid || data.parent().parent().parent().child('hostId').val() === auth.uid",
              ".validate": "newData.isString()"
            },
            "role": {
              ".read": "$playerId === auth.uid",
              ".write": "data.parent().parent().parent().child('hostId').val() === auth.uid"
            },
            "isConnected": {
              ".write": "$playerId === auth.uid || data.parent().parent().parent().child('hostId').val() === auth.uid"
            },
            "lastSeen": {
              ".write": "$playerId === auth.uid"
            },
            "disconnectedAt": {
              ".write": "$playerId === auth.uid"
            }
          }
        },
        "reactions": {
          "$reactionId": {
            ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists() && ((newData.exists() && newData.child('playerId').val() === auth.uid) || (!newData.exists() && data.exists() && data.child('playerId').val() === auth.uid))",
            ".validate": "!newData.exists() || (newData.hasChildren(['emoji', 'playerName', 'playerId', 'timestamp']) && newData.child('playerId').val() === auth.uid)"
          }
        },
        "currentWord": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "currentImpostors": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "currentRoundStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "cluePhaseStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "votingPhaseStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "turnOrder": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "currentTurnIndex": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "voteCounts": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "isTie": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "lastEliminatedId": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "winner": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "roundDecisionVotes": {
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "newData.isString() && newData.val().matches(/^(go_vote|another_round)$/)"
          },
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "roundDecisionStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "clueRound": {
          ".write": "data.parent().child('hostId').val() === auth.uid",
          ".validate": "newData.isNumber()"
        },
        "postResultVotes": {
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "newData.isString() && newData.val().matches(/^(play_again|leave)$/)"
          },
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "postResultStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "eliminationChoiceVotes": {
          "$playerId": {
            ".write": "$playerId === auth.uid || data.parent().parent().child('hostId').val() === auth.uid",
            ".validate": "newData.isString() && newData.val().matches(/^(continue_same|reveal_impostor)$/)"
          },
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "eliminationChoiceStartTime": {
          ".write": "data.parent().child('hostId').val() === auth.uid"
        },
        "lastActivity": {
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "createdAt": {
          ".write": "!data.exists()"
        }
      }
    }
  }
}
